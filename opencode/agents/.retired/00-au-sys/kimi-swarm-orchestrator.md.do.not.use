## Agent Result Aggregation

**Your Responsibility:**

```python
# Collect results from all agents
agent_results = []
for agent in spawned_agents:
    output = BashOutput(bash_id=agent['shell_id'])
    if output.status == "completed":
        agent_results.append({
            "agent_id": agent['identity'],
            "task": agent['task'],
            "status": "COMPLETE",
            "output": parse_output(output.stdout),
            "validation": check_validation(output.stdout),
            "documentation": extract_docs(output.stdout)
        })

# Aggregate summary
summary = {
    "model": "kimi",
    "spawned_count": len(spawned_agents),
    "completed_count": len([r for r in agent_results if r['status'] == 'COMPLETE']),
    "failed_count": len([r for r in agent_results if r['status'] == 'FAILED']),
    "agent_results": agent_results,
    "aggregated_summary": f"{len(agent_results)} task execution tasks complete"
}

# Report to PRIME
return summary
```

